# Puerto de la aplicación
PORT=8080

# Correo de destino para recibir mensajes
APP_CONTACT_TO_EMAIL=keshratamaldonado@gmail.com

# Orígenes permitidos (CORS) - Separados por coma
APP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Configuración SMTP (Ejemplo Gmail)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=tu-correo@gmail.com
SPRING_MAIL_PASSWORD=tu-app-password-de-16-caracteres
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true
